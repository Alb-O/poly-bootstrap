{
  repoDirsPath: "repos"

  root: {
    layers: []
  }

  inputs: {}

  layers: {
    empty: {}
  }

  repos: {
    app: {
      path: "repos/app"
      layers: [ "empty" ]
      bootstrapDeps: [ "dep" ]
      bootstrapTasks: [ "devenv:files" ]
    }
    dep: {
      path: "repos/dep"
      layers: [ "empty" ]
      bootstrapDeps: [ "transitive" ]
      bootstrapTasks: [ "devenv:files" ]
    }
    transitive: {
      path: "repos/transitive"
      layers: [ "empty" ]
      bootstrapTasks: [ "devenv:files" ]
    }
  }
}
