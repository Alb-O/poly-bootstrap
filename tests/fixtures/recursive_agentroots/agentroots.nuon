{
  repoDirsPath: "repos"

  root: {
    layers: [ "shared-tooling" ]
  }

  inputs: {
    docs-shared: {
      url: "github:Alb-O/ar_docs_env"
      flake: false
      imports: [ "docs-shared/subdir" ]
      localRepo: "ar_docs_env"
    }
    nusurf: {
      url: "github:Alb-O/nusurf"
      flake: false
      imports: [ "nusurf/nushell-plugin" ]
      requiresInputs: [ "ar_rust_env" ]
      localRepo: "nusurf"
    }
    agentroots: {
      url: "github:Alb-O/agentroots"
      flake: false
      imports: [ "agentroots/tooling" ]
      localRepo: "agentroots"
    }
    ar_rust_env: {
      url: "github:Alb-O/ar_rust_env"
      flake: false
      localRepo: "ar_rust_env"
    }
  }

  layers: {
    shared-tooling: {
      inputs: [ "nusurf" "agentroots" ]
    }
    repo-empty: {
      extends: [ "shared-tooling" ]
    }
    repo_bootstrap_dep: {
      extends: [ "shared-tooling" ]
      inputs: [ "docs-shared" ]
    }
  }

  repoGroups: {
    dependency-repos: {
      members: {
        nusurf: "repos/nusurf"
        agentroots: "repos/agentroots"
        ar_docs_env: "repos/ar_docs_env"
        ar_rust_env: "repos/ar_rust_env"
      }
      layers: [ "repo-empty" ]
    }
  }

  repos: {
    bootstrap_dep: {
      path: "repos/bootstrap_dep"
      layers: [ "repo_bootstrap_dep" ]
      bootstrapTasks: [ "devenv:files" ]
    }
    app: {
      path: "repos/app"
      layers: [ "repo-empty" ]
      bootstrapDeps: [ "bootstrap_dep" ]
      bootstrapTasks: [ "devenv:files" ]
    }
  }
}
