{
  repoDirsPath: "repos"

  root: {
    layers: [ "shared-tooling" ]
  }

  inputs: {
    ar_devenv_base: {
      url: "github:Alb-O/ar_devenv_base"
      flake: false
      imports: [ "ar_devenv_base" ]
      localRepo: "ar_devenv_base"
    }
    docs-shared: {
      url: "github:Alb-O/ar_devenv_docs"
      flake: false
      imports: [ "docs-shared/subdir" ]
      localRepo: "ar_devenv_docs"
    }
    nusurf: {
      url: "github:Alb-O/nusurf"
      flake: false
      imports: [ "nusurf/nushell-plugin" ]
      requiresInputs: [ "ar_devenv_rust" ]
      localRepo: "nusurf"
    }
    agentroots: {
      url: "github:Alb-O/agentroots"
      flake: false
      imports: [ "agentroots/tooling" ]
      localRepo: "agentroots"
    }
    ar_devenv_rust: {
      url: "github:Alb-O/ar_devenv_rust"
      flake: false
      localRepo: "ar_devenv_rust"
    }
  }

  layers: {
    shared-tooling: {
      inputs: [ "ar_devenv_base" "nusurf" "agentroots" ]
    }
    repo-empty: {
      extends: [ "shared-tooling" ]
    }
    repo_bootstrap_dep: {
      extends: [ "shared-tooling" ]
      inputs: [ "docs-shared" ]
    }
  }

  repoGroups: {
    dependency-repos: {
      members: {
        nusurf: "repos/nusurf"
        agentroots: "repos/agentroots"
        ar_devenv_base: "repos/ar_devenv_base"
        ar_devenv_docs: "repos/ar_devenv_docs"
        ar_devenv_rust: "repos/ar_devenv_rust"
      }
      layers: [ "repo-empty" ]
    }
  }

  repos: {
    bootstrap_dep: {
      path: "repos/bootstrap_dep"
      layers: [ "repo_bootstrap_dep" ]
      bootstrapTasks: [ "devenv:files" ]
    }
    app: {
      path: "repos/app"
      layers: [ "repo-empty" ]
      bootstrapDeps: [ "bootstrap_dep" ]
      bootstrapTasks: [ "devenv:files" ]
    }
  }
}
