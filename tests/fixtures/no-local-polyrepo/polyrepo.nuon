{
  repoDirsPath: "repos"

  rootProfiles: [ "local-only" ]
  repoDefaultProfiles: [ "local-only" ]

  inputs: {
    agent-scripts: {
      url: "github:Alb-O/agent-scripts"
      flake: false
    }
  }

  bundles: {
    empty: {}
  }

  profiles: {
    local-only: {
      inputs: [ "agent-scripts" ]
    }
  }

  repos: {
    app: {
      path: "repos/app"
      bundle: "empty"
    }
  }
}
