{
  repoDirsPath: "repos"

  root: {
    layers: [ "remote-only" ]
  }

  inputs: {
    agent-scripts: {
      url: "github:Alb-O/agent-scripts"
      flake: false
    }
  }

  layers: {
    remote-only: {
      inputs: [ "agent-scripts" ]
    }
  }

  repos: {
    app: {
      path: "repos/app"
      layers: [ "remote-only" ]
    }
  }
}
