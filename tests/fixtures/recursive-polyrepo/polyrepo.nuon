{
  repoDirsPath: "repos"

  repos: [
    "repos/agent-scripts"
    "repos/app"
    "repos/nusurf"
    "repos/poly-docs-env"
  ]

  sharedInputs: {
    docs-shared: {
      url: "github:Alb-O/poly-docs-env"
      flake: false
      imports: [ "docs-shared/subdir" ]
    }
    remote-global: {
      url: "github:Alb-O/remote-global"
      flake: false
      imports: [ "remote-global" ]
    }
    agent-scripts: {
      url: "github:Alb-O/agent-scripts"
      flake: false
      imports: [ "agent-scripts/tooling" ]
    }
    nusurf: {
      url: "github:Alb-O/nusurf"
      flake: false
      imports: [ "nusurf/nushell-plugin" ]
    }
    poly-rust-env: {
      url: "github:Alb-O/poly-rust-env"
      flake: false
    }
  }
}
