{
  repoDirsPath: "repos"

  root: {
    layers: [ "shared-tooling" ]
  }

  inputs: {
    agent-scripts: {
      url: "github:Alb-O/agent-scripts"
      flake: false
      imports: [ "agent-scripts/tooling" ]
      requiresInputs: [ "docs-shared" ]
      localRepo: "agent-scripts"
    }
    docs-shared: {
      url: "github:Alb-O/poly-docs-env"
      flake: false
      imports: [ "docs-shared/subdir" ]
      localRepo: "poly-docs-env"
    }
    nusurf: {
      url: "github:Alb-O/nusurf"
      flake: false
      imports: [ "nusurf/nushell-plugin" ]
      requiresInputs: [ "poly-rust-env" ]
      localRepo: "nusurf"
    }
    poly-rust-env: {
      url: "github:Alb-O/poly-rust-env"
      flake: false
      localRepo: "poly-rust-env"
    }
  }

  layers: {
    shared-tooling: {
      inputs: [ "agent-scripts" "nusurf" ]
    }
    repo-empty: {
      extends: [ "shared-tooling" ]
    }
    repo-agent-scripts: {
      extends: [ "shared-tooling" ]
      inputs: [ "docs-shared" ]
    }
  }

  repoGroups: {
    dependency-repos: {
      members: {
        nusurf: "repos/nusurf"
        poly-docs-env: "repos/poly-docs-env"
        poly-rust-env: "repos/poly-rust-env"
      }
      layers: [ "repo-empty" ]
    }
  }

  repos: {
    agent-scripts: {
      path: "repos/agent-scripts"
      layers: [ "repo-agent-scripts" ]
      bootstrapTasks: [ "devenv:files" ]
    }
    app: {
      path: "repos/app"
      layers: [ "repo-empty" ]
      bootstrapDeps: [ "agent-scripts" ]
      bootstrapTasks: [ "devenv:files" ]
    }
  }
}
