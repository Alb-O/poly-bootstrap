{
  repoDirsPath: "repos"

  rootProfiles: [ "shared-tooling" ]
  repoDefaultProfiles: [ "shared-tooling" ]

  inputs: {
    agent-scripts: {
      url: "github:Alb-O/agent-scripts"
      flake: false
      imports: [ "agent-scripts/tooling" ]
      requiresInputs: [ "docs-shared" ]
    }
    docs-shared: {
      url: "github:Alb-O/poly-docs-env"
      flake: false
      localRepo: "poly-docs-env"
      imports: [ "docs-shared/subdir" ]
    }
    nusurf: {
      url: "github:Alb-O/nusurf"
      flake: false
      imports: [ "nusurf/nushell-plugin" ]
      requiresInputs: [ "poly-rust-env" ]
    }
    poly-rust-env: {
      url: "github:Alb-O/poly-rust-env"
      flake: false
    }
  }

  bundles: {
    empty: {}
    agent-scripts-bundle: {
      inputs: [ "docs-shared" ]
    }
    nusurf-bundle: {
      inputs: [ "poly-rust-env" ]
    }
  }

  profiles: {
    shared-tooling: {
      inputs: [ "agent-scripts" "nusurf" ]
    }
  }

  repos: {
    agent-scripts: {
      path: "repos/agent-scripts"
      bundle: "agent-scripts-bundle"
    }
    app: {
      path: "repos/app"
      bundle: "empty"
    }
    nusurf: {
      path: "repos/nusurf"
      bundle: "nusurf-bundle"
    }
    poly-docs-env: {
      path: "repos/poly-docs-env"
      bundle: "empty"
    }
    poly-rust-env: {
      path: "repos/poly-rust-env"
      bundle: "empty"
    }
  }
}
