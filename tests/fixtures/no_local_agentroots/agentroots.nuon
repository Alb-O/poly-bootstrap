{
  repoDirsPath: "repos"

  root: {
    layers: [ "remote-only" ]
  }

  inputs: {
    remote_tools: {
      url: "github:Alb-O/remote_tools"
      flake: false
    }
  }

  layers: {
    remote-only: {
      inputs: [ "remote_tools" ]
    }
  }

  repos: {
    app: {
      path: "repos/app"
      layers: [ "remote-only" ]
    }
  }
}
