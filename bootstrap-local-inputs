#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="${1:-.}"
output_path="$repo_root/devenv.local.yaml"
lock_path="$repo_root/devenv.lock"
nu_script="$script_dir/poly-local-inputs.nu"

run_nu() {
  if command -v nu >/dev/null 2>&1; then
    nu "$@"
  else
    nix --extra-experimental-features 'nix-command flakes' \
      shell "path:${script_dir}/nix/flake-bootstrap#nushell" \
      -c nu "$@"
  fi
}

run_sync() {
  run_nu "$nu_script" sync "$@"
}

# `devenv.local.yaml` affects the root input graph, but `devenv.lock` still
# controls which inputs are actually present during evaluation. If the local
# overrides gain a new transitive input like `pw`, a plain regen of the YAML is
# not enough; the lock must also be refreshed so the root node exposes it.
lock_needs_refresh() {
  if [ ! -f "$output_path" ]; then
    return 1
  fi

  if [ ! -f "$lock_path" ]; then
    return 0
  fi

  local status
  status="$(run_nu "$nu_script" lock-status "$output_path" "$lock_path")"

  [ "$status" != "clean" ]
}

before_hash="__missing__"
if [ -f "$output_path" ]; then
  before_hash="$(sha256sum "$output_path")"
fi

run_sync "$@"

after_hash="__missing__"
if [ -f "$output_path" ]; then
  after_hash="$(sha256sum "$output_path")"
fi

# Refresh the lock when either:
# 1. the generated override file changed, or
# 2. the override file stayed the same but now disagrees with the lock's root
#    inputs/path nodes. Case 2 is the stale-lock failure mode that produced
#    `attribute 'pw' missing` even after regenerating `devenv.local.yaml`.
refresh_needed=0
if lock_needs_refresh; then
  refresh_needed=1
fi

if [ "$before_hash" != "$after_hash" ]; then
  refresh_needed=1
fi

if [ "$refresh_needed" -eq 1 ]; then
  (
    cd "$repo_root"
    devenv update >/dev/null
  )
fi
