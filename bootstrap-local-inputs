#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="${1:-.}"
output_path="$repo_root/devenv.local.yaml"
lock_path="$repo_root/devenv.lock"

run_python() {
  if python3 -c 'import yaml' >/dev/null 2>&1; then
    python3 "$@"
  else
    nix --extra-experimental-features 'nix-command flakes' \
      shell "path:${script_dir}/nix/flake-bootstrap#pyyaml" \
      -c python3 "$@"
  fi
}

run_sync() {
  run_python "$script_dir/poly-local-inputs.py" sync "$@"
}

# `devenv.local.yaml` affects the root input graph, but `devenv.lock` still
# controls which inputs are actually present during evaluation. If the local
# overrides gain a new transitive input like `pw`, a plain regen of the YAML is
# not enough; the lock must also be refreshed so the root node exposes it.
lock_needs_refresh() {
  if [ ! -f "$output_path" ]; then
    return 1
  fi

  if [ ! -f "$lock_path" ]; then
    return 0
  fi

  local status
  status="$(
    run_python - "$output_path" "$lock_path" <<'PY'
import json
import sys
from pathlib import Path

import yaml

output_path = Path(sys.argv[1])
lock_path = Path(sys.argv[2])

local_doc = yaml.safe_load(output_path.read_text(encoding="utf-8")) or {}
desired_inputs = local_doc.get("inputs", {}) or {}

if not desired_inputs:
    print("clean")
    raise SystemExit(0)

lock_doc = json.loads(lock_path.read_text(encoding="utf-8"))
root_name = lock_doc.get("root")
root_node = (lock_doc.get("nodes") or {}).get(root_name, {})
root_inputs = root_node.get("inputs", {}) or {}
nodes = lock_doc.get("nodes") or {}

for input_name, input_spec in desired_inputs.items():
    if input_name not in root_inputs:
        print(f"missing-root-input:{input_name}")
        raise SystemExit(0)

    url = (input_spec or {}).get("url")
    if not isinstance(url, str):
        continue

    expected_path = None
    if url.startswith("path:"):
        expected_path = url[len("path:") :]
    elif url.startswith("git+file:"):
        expected_path = url[len("git+file:") :]

    if expected_path is None:
        continue

    node_name = root_inputs[input_name]
    node = nodes.get(node_name, {})
    locked = node.get("locked") or {}
    original = node.get("original") or {}
    candidate_paths = {
        locked.get("path"),
        original.get("path"),
    }

    if expected_path not in candidate_paths:
        print(f"stale-path:{input_name}")
        raise SystemExit(0)

print("clean")
PY
  )"

  [ "$status" != "clean" ]
}

before_hash="__missing__"
if [ -f "$output_path" ]; then
  before_hash="$(sha256sum "$output_path")"
fi

run_sync "$@"

after_hash="__missing__"
if [ -f "$output_path" ]; then
  after_hash="$(sha256sum "$output_path")"
fi

# Refresh the lock when either:
# 1. the generated override file changed, or
# 2. the override file stayed the same but now disagrees with the lock's root
#    inputs/path nodes. Case 2 is the stale-lock failure mode that produced
#    `attribute 'pw' missing` even after regenerating `devenv.local.yaml`.
refresh_needed=0
if lock_needs_refresh; then
  refresh_needed=1
fi

if [ "$before_hash" != "$after_hash" ]; then
  refresh_needed=1
fi

if [ "$refresh_needed" -eq 1 ]; then
  (
    cd "$repo_root"
    devenv update >/dev/null
  )
fi
