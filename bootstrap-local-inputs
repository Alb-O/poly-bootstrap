#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="${1:-.}"
nu_script="$script_dir/poly-local-inputs.nu"

run_nu() {
  if command -v nu >/dev/null 2>&1; then
    nu "$@"
  else
    nix --extra-experimental-features 'nix-command flakes' \
      shell "path:${script_dir}/nix/flake-bootstrap#nushell" \
      -c nu "$@"
  fi
}

run_sync_json() {
  run_nu "$nu_script" sync --json "$@"
}

sync_status_json="$(run_sync_json "$@")"

if [ -z "$sync_status_json" ]; then
  refresh_needed=0
else
  refresh_needed="$(
    printf '%s' "$sync_status_json" | run_nu -c '
      let status = ($in | from json)
      if ($status.changed or $status.lock_refresh_needed) { "1" } else { "0" }
    '
  )"
fi

if [ "$refresh_needed" -eq 1 ]; then
  (
    cd "$repo_root"
    devenv update >/dev/null
  )
fi
